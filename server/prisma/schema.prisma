datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String      @id @default(uuid())
  uid            String      @unique
  firebaseUid    String?     @unique
  email          String      @unique
  password       String?
  name           String
  firstName      String
  avatar         String?
  role           String
  isExecutive    Boolean     @default(false)
  isManager      Boolean     @default(false)
  status         String      @default("offline")
  timeEntries    TimeEntry[]
  tasks          Task[]         @relation("AssignedTasks")
  createdTasks   Task[]         @relation("CreatedTasks")
  approvedTasks  Task[]         @relation("ApprovedTasks")
  notifications  Notification[]
  attendances    Attendance[]
  attendanceLogs AttendanceLog[]
  workLogs       WorkLog[]
  standups        Standup[]
  sentBroadcasts  Broadcast[]    @relation("BroadcastSender")
  readBroadcasts  BroadcastRead[]
  sentMessages    Message[]      @relation("MessageSender")
  receivedMessages Message[]     @relation("MessageReceiver")
  tokens          Token[]        @relation("TokenOwner")
  reviewedTokens  Token[]        @relation("TokenReviewer")
  bookmarks       Bookmark[]
  codeSnippets    CodeSnippet[]
  activityLogs    ActivityLog[]
  createdAt       DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Project {
  id          String      @id @default(uuid())
  name        String
  description String?
  client      String?
  status      String      @default("Active")
  progress    Int         @default(0)
  dueDate     DateTime?
  members     String[]
  sprints     Sprint[]
  tasks       Task[]
  workLogs    WorkLog[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Sprint {
  id          String      @id @default(uuid())
  name        String
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Task {
  id             String    @id @default(uuid())
  title          String
  description    String?
  priority       String    @default("MEDIUM")
  status         String    @default("TASKS")
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId       String?
  sprint         Sprint?   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  assignedTo     String?
  assigneeUser   User?     @relation("AssignedTasks", fields: [assignedTo], references: [uid])
  assignedBy     String
  assignerUser   User      @relation("CreatedTasks", fields: [assignedBy], references: [uid])
  dueDate        DateTime?
  estimatedHours Int?
  testingNotes   String?
  completedAt    DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  approverUser   User?     @relation("ApprovedTasks", fields: [approvedBy], references: [uid])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [uid])
  title     String
  message   String
  type      String
  taskId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TimeEntry {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  startTime       DateTime
  endTime         DateTime?
  durationSeconds Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Client {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Attendance {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  date            DateTime // Stored as midnight of the day
  isPresent       Boolean  @default(false)
  approvedBy      String?  // userId of Mr.K
  clockInTime     DateTime? // First clock-in of the day — never overwritten
  sessionStartTime DateTime? // Start of current session — resets each clock-in
  clockOutTime    DateTime?
  totalDuration   Int      @default(0) // in seconds, accumulates all day
  presenceStatus  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([userId, date])
}

model AttendanceLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  attendanceId String
  type         String   // 'CLOCK_IN' or 'CLOCK_OUT'
  time         DateTime
  status       String   // presence mode at time of punch
  createdAt    DateTime @default(now())
}

model WorkLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  description String
  minutes     Int
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Standup {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  date        DateTime
  yesterday   String
  today       String
  blockers    String?
  createdAt   DateTime @default(now())
  
  @@unique([userId, date])
}

model Broadcast {
  id          String   @id @default(uuid())
  title       String
  message     String
  sender      User     @relation("BroadcastSender", fields: [sentBy], references: [id])
  sentBy      String
  targetRole  String?  // null = all users
  createdAt   DateTime @default(now())
  reads       BroadcastRead[]
}

model BroadcastRead {
  id          String    @id @default(uuid())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  broadcastId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  readAt      DateTime  @default(now())

  @@unique([broadcastId, userId])
}

model Message {
  id          String   @id @default(uuid())
  fromUser    User     @relation("MessageSender", fields: [fromUserId], references: [id])
  fromUserId  String
  toUser      User     @relation("MessageReceiver", fields: [toUserId], references: [id])
  toUserId    String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Token {
  id          String   @id @default(uuid())
  user        User     @relation("TokenOwner", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        String   // LEAVE, LATE_ARRIVAL, EARLY_DEPARTURE, WFH, ABSENT
  date        DateTime
  reason      String
  note        String?
  status      String   @default("PENDING")
  reviewer    User?    @relation("TokenReviewer", fields: [reviewedBy], references: [id])
  reviewedBy  String?
  reviewNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bookmark {
  id          String   @id @default(uuid())
  title       String
  url         String
  category    String
  description String?
  user        User     @relation(fields: [addedBy], references: [id])
  addedBy     String
  createdAt   DateTime @default(now())
}

model CodeSnippet {
  id          String   @id @default(uuid())
  title       String
  language    String
  code        String
  tags        String[]
  user        User     @relation(fields: [addedBy], references: [id])
  addedBy     String
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  eventType   String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
}
